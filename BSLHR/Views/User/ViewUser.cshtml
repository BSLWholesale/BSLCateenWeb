
@{
    ViewBag.Title = "ViewUser";
}

@{
    
    @*<script src="~/Edumin/js/jquery-3.4.1.min.js"></script>*@
    <link href="~/Edumin/vendor/datatables/css/jquery.dataTables.min.css" rel="stylesheet" />

   <script type="text/javascript">
       $(document).ready(function () {
           Fn_Get_All_Employee();
       });

       function Fn_Get_All_Employee() {

           var clsEmployee = {};

           $.ajax({
               type: "POST",
               url: "/User/Fn_Get_All_Employee",
               contentType: "application/json; charset=utf-8",
               dataType: "json",
               data: JSON.stringify(clsEmployee),
               success: function (data) {
                   var obj = JSON.parse(data.message);
                   if (obj[0].vErrorMsg == "Success") {
                       var html = '';
                       $("#tbody").html('');
                       for (var i = 0; i < obj.length; i++) {
                           html += "<tr>";
                           
                           html += "<td>" + obj[i].EmpId + "</td>";
                           html += "<td>" + obj[i].EmpName + "</td>";
                           html += "<td>" + obj[i].DOB + "</td>";
                           html += "<td>" + obj[i].EmpEmailId + "</td>";
                           html += "<td>" + obj[i].EmpMobile + "</td>";
                           html += "<td>" + obj[i].EmpLocation + "</td>";
                           html += "<td>" + obj[i].EmpGrade + "</td>";
                           html += "<td>" + obj[i].BSLTravelDesk + "</td>";
                           html += "<td>" + obj[i].EmpPassword + "</td>";
                           html += "<td>" + obj[i].BSLTravelDesk + "</td>";
                           html += "<td>" + obj[i].EmpPassword + "</td>";
                           html += "<td><a href='javascript:void (0);' class='btn btn-xs sharp btn-primary'><i class='fa fa-pencil'></i></a>";
                           html += "<a href='javascript:void(0);' class='btn btn-xs sharp btn-danger'> <i class='fa fa-trash'></i></a></th>";
                           html += "</tr>";
                       }
                       $("#tbody").append(html);
                   }
                   else {
                       html += "<tr><td colspan='12'>No record found.</td></tr>";
                   }

               },
               error: function (err) {
                   alert(err);

               }
           });
       }
   </script>
}


<div class="content-body">
    <!-- row -->
    <div class="container-fluid">

        <div class="row page-titles mx-0">
            <div class="col-sm-6 p-md-0">
                <div class="welcome-text">
                    <h4>All Employee</h4>
                </div>
            </div>
            <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
                <ol class="breadcrumb">

                    <li class="breadcrumb-item"><a href="javascript:void(0);">Employee</a></li>
                    <li class="breadcrumb-item active"><a href="javascript:void(0);">View Employee</a></li>
                </ol>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-12">
                <div class="row tab-content">
                    <div id="list-view" class="tab-pane fade active show col-lg-12">
                        <div class="card">
                            <div class="card-header">
                                <h4 class="card-title">All Employee List  </h4>
                                <a href="@Url.Action("AddUser", "User")" class="btn btn-primary">+ Add new</a>
                            </div>
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table id="example3" class="display text-nowrap" style="min-width: 845px">
                                        <thead>
                                            <tr>
                                                <th>Emp ID</th>
                                                <th>Emp Name</th>
                                                <th>DOB</th>
                                                <th>Email</th>
                                                <th>Mobile</th>
                                                <th>Location</th>
                                                <th>Grade</th>
                                                <th>Travell Desk</th>
                                                <th>Password</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tbody">
                                          
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>



<!--**********************************    Content body end ***********************************-->
<!-- Datatable -->
<script src="~/Edumin/vendor/datatables/js/jquery.dataTables.min.js"></script>
<script src="~/Edumin/js/plugins-init/datatables.init.js"></script>