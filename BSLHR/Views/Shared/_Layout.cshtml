<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - BSLHR</title>

    <!-- Favicon icon -->
    <link rel="icon" type="image/png" sizes="16x16" href="~/Edumin/images/favicon.png">

    <link href="~/Edumin/vendor/bootstrap-select/dist/css/bootstrap-select.min.css" rel="stylesheet">
    <!--**********************************
        Style script start
    ***********************************-->
    <script src="~/Edumin/js/jquery-3.4.1.min.js"></script>

    <link rel="stylesheet" href="~/Edumin/vendor/pickadate/themes/default.css">
    <link rel="stylesheet" href="~/Edumin/vendor/pickadate/themes/default.date.css">

    <!--**********************************
        Style script end
    ***********************************-->
    <!-- Style css -->
    <link class="main-css" href="~/Edumin/css/style.css" rel="stylesheet">

    <script type="text/javascript">

        $(document).ready(function () {

            var strLogInId = sessionStorage.getItem("LogInID");
            var UserName = sessionStorage.getItem("UserName");
            if (strLogInId == null || strLogInId == 0) {
                window.location.href = '/Home/Index';
            }
        });

    </script>

</head>
<body>
    Preloader start
    ********************-->
    <div id="preloader">
        <div class="sk-three-bounce">
            <div class="sk-child sk-bounce1"></div>
            <div class="sk-child sk-bounce2"></div>
            <div class="sk-child sk-bounce3"></div>
        </div>
    </div>
    <!--*******************
        Preloader end
    ********************-->
    <div id="main-wrapper">

        @Html.Partial("_Header")

        @RenderBody()

        <footer>
            @Html.Partial("_Footer")
        </footer>

    </div>
    <script src="~/Edumin/vendor/global/global.min.js"></script>
    <script src="~/Edumin/vendor/bootstrap-select/dist/js/bootstrap-select.min.js"></script>

    <!-- Chart Morris plugin files -->
    <script src="~/Edumin/vendor/raphael/raphael.min.js"></script>
    <script src="~/Edumin/vendor/morris/morris.min.js"></script>

    <!-- Chart piety plugin files -->
    <script src="~/Edumin/vendor/peity/jquery.peity.min.js"></script>


    <!-- Svganimation scripts -->
    <script src="~/Edumin/vendor/svganimation/vivus.min.js"></script>
    <script src="~/Edumin/vendor/svganimation/svg.animation.js"></script>
    <!-- Demo scripts -->
    <script src="~/Edumin/js/dashboard/dashboard-2.js"></script>

    <!-- momment js is must -->
    <script src="~/Edumin/vendor/bootstrap-daterangepicker/daterangepicker.js"></script>
    <!-- pickdate -->
    <script src="~/Edumin/vendor/pickadate/picker.js"></script>
    <script src="~/Edumin/vendor/pickadate/picker.time.js"></script>
    <script src="~/Edumin/vendor/pickadate/picker.date.js"></script>
    <script src="~/Edumin/js/plugins-init/pickadate-init.js"></script>
    <!-- Pickdate -->

    <script src="~/Edumin/js/custom.min.js"></script>
    <script src="~/Edumin/js/dlabnav-init.js"></script>
    <script src="~/Edumin/js/demo.js"></script>
    <script src="~/Edumin/js/styleSwitcher.js"></script>
</body>
</html>