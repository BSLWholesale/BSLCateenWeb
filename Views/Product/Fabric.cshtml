    <script>
        var ErrorMsg = '';
        function fn_Blank_Control() {
            $('#txtQualityNumber').val('');
            $('#txtPriceRange').val('');
            $('#txtBlendDesc').val('');
            $('#txtWeaveType').val('');
            $('#txtWeight').val('');
            $('#txtStretchType').val('');
            $('#txtDesignPattern').val('');
            $('#txtNoQty').val('');
            $('#txtRemarks').val('');
        }
        function Validate_Control(ErrorMsg) {
            if ($('#txtQualityNumber').val() == '') {
                ErrorMsg = "Quantity is Quantity Number";
            }
            if ($('#txtPriceRange').val() == '') {
                ErrorMsg = "Quantity is Price Range";
            }
            if ($('#txtBlendDesc').val() == '') {
                ErrorMsg = "Quantity is Blend Description";
            }
            if ($('#txtWeaveType').val() == '') {
                ErrorMsg = "Quantity is Weave Type";
            }
            if ($('#txtWeight').val() == '') {
                ErrorMsg = "Quantity is Weight";
            }
            if ($('#txtStretchType').val() == '') {
                ErrorMsg = "Quantity is Stretch Type";
            }
            if ($('#txtDesignPattern').val() == '') {
                ErrorMsg = "Quantity is Design Pattern";
            }
            if ($('#txtNoQty').val() == '') {
                ErrorMsg = "Quantity is blank";
            }
        }

        function fn_Save_Customize_Data() {

            var clsCustomize = {};
            clsCustomize.ErrorMsg = '';
            if ($('#txtQualityNumber').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Quantity Number";
            }
            else if ($('#txtPriceRange').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Price Range";
            }
            else if ($('#txtBlendDesc').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Blend Description";
            }
            else if ($('#txtWeaveType').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Weave Type";
            }
            else if ($('#txtWeight').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Weight";
            }
            else if ($('#txtStretchType').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Stretch Type";
            }
            else if ($('#txtDesignPattern').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is Design Pattern";
            }
            else if ($('#txtNoQty').val() == '') {
                clsCustomize.ErrorMsg = "Quantity is blank";
            }

            Validate_Control(clsCustomize.ErrorMsg);
            clsCustomize.QuantityNumber = $('#txtQualityNumber').val();
            clsCustomize.PriceRange = $('#txtPriceRange').val();
            clsCustomize.BlendDescription = $('#txtBlendDesc').val();
            clsCustomize.WeaveType = $('#txtWeaveType').val();
            clsCustomize.Weight = $('#txtWeight').val();
            clsCustomize.StretchType = $('#txtStretchType').val();
            clsCustomize.DesignPattern = $('#txtDesignPattern').val();

            clsCustomize.Quantity = $('#txtNoQty').val();
            clsCustomize.Remarks = $('#txtRemarks').val();

            if (clsCustomize.ErrorMsg == '') {
                $.ajax({
                    type: "POST",
                    url: '/Product/Fn_Save_CustomizeData',
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",

                    data: JSON.stringify(clsCustomize),
                    success: function (data) {
                        fn_Blank_Control();
                        if (data.clsCustomize.ErrorMsg == 'success') {
                            //alert(data.ErrorMsg);
                            alert('Customize data Added Successfully')
                        }
                        else {
                            alert('Customize data Not Added')
                        }
                    },
                    error: function (err) {
                        alert(err);
                    }
                });
            }
            else {
                alert(clsCustomize.ErrorMsg);
            }
        }

        function insert_cart(id) {

            var clsRequestProduct = {};
            var nameProduct = $('.shop-item-title').html();
            var myString = $('.shop-item-price').html();;
            var myNewString = myString.replace("$", "");
            debugger;
            clsRequestProduct.vCategory = 'Fabric';
            clsRequestProduct.nProductId = id;
            clsRequestProduct.vProductName = nameProduct;
            clsRequestProduct.vGround = 'Blue';
            clsRequestProduct.vBorder = 'Blue';
            clsRequestProduct.vSize = 'S';
            clsRequestProduct.vPrice = myNewString;
            clsRequestProduct.nQuantity = 1;
            clsRequestProduct.bIsStatus = false;

            if (clsRequestProduct.vSize === undefined) {
                swal(nameProduct, "Please select size !", "success");
            } else {
                debugger;
                $.ajax({
                    type: "POST",
                    url: '/Product/Fn_Insert_Cart',
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    data: JSON.stringify(clsRequestProduct),
                    success: function (Result) {

                        if (Result.success == true) {
                            Fn_GetCount_Item();
                            swal(nameProduct, "is added to cart !", "success");
                        }
                        else {
                            // alert("No stock left !");
                            swal(nameProduct, "No stock left !", "error");
                        }
                    }
                });
            }
        }


    </script>

    <script type="text/javascript">
        function Fn_GetCount_Item() {

            var clsRequestProduct = {};
            clsRequestProduct.vCustomerId = $('#strUserId').val();
            $.ajax({
                type: "POST",
                url: '/Product/Fn_Get_Count_Cart_Item',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsRequestProduct),
                success: function (data) {
                    var pcount = data.message;
                    if (data.success == true) {
                        $('#Allcart').html(pcount);
                    }
                    else {
                        alert('Customize data Not Added')
                    }
                },
                error: function (err) {
                    alert(err);
                }
            });
        }

        $(document).ready(function () {
            Fn_GetCount_Item();
        });
    </script>
}

