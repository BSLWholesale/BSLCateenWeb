<script>
    const targetDiv = document.getElementById("divFebric");
    const targetDiv2 = document.getElementById("divCustomize");
    const btn = document.getElementById("mybtn");
    btn.onclick = function () {
        if (targetDiv.style.display !== "none" || targetDiv2.style.display == "none") {
            targetDiv.style.display = "none";
            targetDiv2.style.display = "block";
            /* $('#mybtn').text = 'Back';*/
            $("#mybtn").html('Back');
        } else {
            targetDiv2.style.display = "none";
            targetDiv.style.display = "block";
            /*  $('#mybtn').text = 'Customized Fabric';*/
            $("#mybtn").html('Customized Fabric');
        }
    };
</script>

