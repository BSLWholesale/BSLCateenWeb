@model IEnumerable<BSLWeb.Models.clsProductCart>

@{
    if (Session["UserId"] == null)
    {
        Response.Redirect("~/Home/LogIn");
    }

    ViewBag.Title = "Cart";
}

@{
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" type="text/css" href="~/web/css/style.css">
    <script src="~/Web/js/sweetalert.min.js"></script>
    @*<link rel="stylesheet" type="text/css" href="~/web/css/cart.css">*@
    <script src="~/Scripts/jquery-3.4.1.js"></script>
    <script type="text/javascript">
        function Fn_GetCount_Item() {

            var clsRequestProduct = {};
            clsRequestProduct.vCustomerId = $('#strUserId').val();
            $.ajax({
                type: "POST",
                url: '/Product/Fn_Get_Count_Cart_Item',
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                data: JSON.stringify(clsRequestProduct),
                success: function (data) {
                    var pcount = data.message;
                    if (data.success == true) {
                        $('#Allcart').html(pcount);
                    }
                    else {
                        alert('Customize data Not Added')
                    }
                },
                error: function (err) {
                    alert(err);
                }
            });
        }

        $(document).ready(function () {
            Fn_GetCount_Item();
        });


