}
<br />
<br />
<br />
<br />
<h2 style="text-align: center; color: #08417b; font-family: 'Times New Roman', Times, serif;">Cart</h2>



<div class="container">

    <div class="col-sm-8">
        @foreach (var item in Model)
        {
            var dir = "";
           // var design =  item.vCategory + item.nProductId + ".jpg";
            if (item.vCategory == "Fabric")
            {
                dir = "fabric/" + item.vCategory + item.nProductId + ".jpg";
            }
            else if (item.vCategory == "Yarn")
            {
                dir = "yarn/" + item.vCategory + item.nProductId + ".jpeg";
            }
            else if (item.vCategory == "Garments")
            {
                dir = "garments/" + item.vCategory + item.nProductId + ".jpeg";
            }
            else
            {
                dir = "";
            }

            var cid = Session["UserId"];
            <div class="row" style="border-bottom: 1px solid black;">
                <div class="col-sm-2">
                    <img class="image" src="~/Web/Images/@dir" width="80px" height="100px">
                    @*<img class="image" src="~/Web/Images/yarn/@design" width="80px" height="100px" />*@
                </div>
                <div class="col-sm-8">
                    <span>@item.vCategory</span><br />
                    <span>@item.vProductName @item.vGround @item.vBorder</span><br />
                    <span>Size: @item.vSize</span><br />
                    <span>Qty: @item.nQuantity</span><br />
                    <span>Rs: @item.vPrice</span>
                    @*<br />
                    <span>Ply: @item.nPly</span><br />
                    <span>Technique: @item.vTechnique</span>*@
                    <br />
                    <br />
                </div>
                <div class="col-sm-2">
                    <br />
                    <br />
                    <img class="image p-t-20" src="~/Web/delete.png" width="20px" title="Remove" id="removeitem" onclick="Fn_DeleteCart_Item(@item.nProductId);" />
                </div>
                <br /> <br />
            </div><br />

        }

    </div>
    <div class="col-sm-4">
        <table>
            <thead>
                <tr>
                    <th style="background-color: #08417b; color: white; text-align: center; font-size: 18px;padding: 8px" colspan="2">Order Summary</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Item Price</td>
                    <td></td>
                </tr>
                <tr>
                    <td>Total Quantity</td>
                    <td></td>
                </tr>
                <tr>
                    <td>Total</td>
                    <td></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>